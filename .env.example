# =============================================================================
# Saudi Sentinel — Environment Variables
# -----------------------------------------------------------------------------
# 1. Copy this file:  cp .env.example .env
# 2. For local development, defaults below work out of the box.
# 3. For production, change all passwords and secrets.
# 4. NEVER commit .env to version control — it is in .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Copernicus Data Space (CDSE) — required for tile ingestion
# Register at: https://dataspace.copernicus.eu → My Account → OAuth Clients
# ---------------------------------------------------------------------------
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# PostgreSQL / PostGIS
# ---------------------------------------------------------------------------
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_pass
POSTGRES_DB=sentinel_catalog

# Airflow and MLflow each use their own database on the same Postgres instance
AIRFLOW_DB_PASSWORD=airflow_dev_pass
MLFLOW_DB_PASSWORD=mlflow_dev_pass

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
AIRFLOW_SECRET_KEY=dev_secret_key_change_in_production_1234

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---------------------------------------------------------------------------
# API Gateway (Level 3)
# ---------------------------------------------------------------------------
JWT_SECRET=dev_jwt_secret_change_in_production_1234

# ---------------------------------------------------------------------------
# React Frontend
# Get a free Mapbox token at: https://account.mapbox.com
# ---------------------------------------------------------------------------
MAPBOX_TOKEN=

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# Email alerts (sent for CRITICAL severity alerts)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@your-domain.com
ALERT_EMAIL_TO=team@your-domain.com

# ---------------------------------------------------------------------------
# Copernicus Climate Data Store — ERA5 wind data (Project 09: Oil Spill)
# Register at: https://cds.climate.copernicus.eu
# ---------------------------------------------------------------------------
CDS_API_KEY=

# ---------------------------------------------------------------------------
# Microsoft Planetary Computer — optional secondary data source
# ---------------------------------------------------------------------------
PC_SDK_SUBSCRIPTION_KEY=

# ---------------------------------------------------------------------------
# Internal service URLs (used by Docker Compose networking)
# Do not change these unless you are running services on separate hosts.
# ---------------------------------------------------------------------------
TILE_API_URL=http://tile-api:8100
MODEL_SERVER_URL=http://model-server:8200
API_GATEWAY_URL=http://api-gateway:8300
AIRFLOW_API_URL=http://airflow-webserver:8080
